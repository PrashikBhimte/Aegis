{
  "manifest_version": 3,
  "name": "Aegis-Live Security Scout",
  "version": "2.0",
  "description": "Aegis-Live: Immersive Guardian for phishing detection",
  "permissions": [
    "scripting",
    "notifications",
    "tabs",
    "storage",
    "tts"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["config.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aegis Threat Vault"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"]
    }
  ]
}
